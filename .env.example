APP_NAME=Lentera
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

# Origin konsol React (untuk CORS). Beberapa origin pisahkan dengan koma.
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- PostgreSQL 16 (§08: BYTEA, gen_random_uuid, citext) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=lentera
DB_USERNAME=lentera
DB_PASSWORD=lentera_secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Moderasi Lapis 2 (Gemini) berjalan asinkron lewat Queue.
# Jalankan worker: php artisan queue:work
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Email (OTP pemulihan) --- dev: log; produksi: smtp
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@lentera.test"
MAIL_FROM_NAME="${APP_NAME}"
# MAIL_HOST=smtp.provider.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=

# --- WhatsApp (OTP login HP) --- SMS TIDAK dipakai.
# provider: log (dev) | gowa (go-whatsapp-web-multidevice self-host) | fonnte | cloud (Meta)
WA_PROVIDER=log
WA_TOKEN=
WA_ENDPOINT=
WA_PHONE_ID=
# gowa (self-host): endpoint = base URL server-nya + basic auth user/pass
# WA_PROVIDER=gowa
# WA_ENDPOINT=http://127.0.0.1:3000
# WA_USERNAME=lentera
# WA_PASSWORD=ganti-yang-kuat
WA_USERNAME=
WA_PASSWORD=

# --- Push notification (pengingat malam §12) ---
# driver: log (dev) | fcm. FCM_CREDENTIALS = path file service-account JSON.
# Aktifkan cron scheduler di VPS: * * * * * php artisan schedule:run
PUSH_DRIVER=log
FCM_CREDENTIALS=

# --- Moderasi Gemini (§06/§11: cloud, tier gratis) ---
# Kosongkan di dev: klasifikasi memakai stub heuristik lokal (tanpa jaringan).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta

# --- Sign in with Google (§1 metode C) ---
# Daftar OAuth client ID yang boleh jadi `aud` ID token (Web/serverClientId,
# Android, iOS), dipisah koma. Backend memverifikasi ID token & cek aud ke sini.
GOOGLE_CLIENT_IDS=

# Rate limit komunitas (kiriman per menit per akun).
COMMUNITY_POST_RATE=6

VITE_APP_NAME="${APP_NAME}"

# JWT (mobile) — isi via: php artisan jwt:secret
JWT_SECRET=
