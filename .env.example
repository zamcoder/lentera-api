APP_NAME=Lentera
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

# Origin konsol React (untuk CORS). Beberapa origin pisahkan dengan koma.
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- PostgreSQL 16 (§08: BYTEA, gen_random_uuid, citext) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=lentera
DB_USERNAME=lentera
DB_PASSWORD=lentera_secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Moderasi Lapis 2 (Gemini) berjalan asinkron lewat Queue.
# Jalankan worker: php artisan queue:work
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@lentera.test"
MAIL_FROM_NAME="${APP_NAME}"

# --- Moderasi Gemini (§06/§11: cloud, tier gratis) ---
# Kosongkan di dev: klasifikasi memakai stub heuristik lokal (tanpa jaringan).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta

# Rate limit komunitas (kiriman per menit per akun).
COMMUNITY_POST_RATE=6

VITE_APP_NAME="${APP_NAME}"
